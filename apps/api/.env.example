# PixSign Pro — API env. Copy to .env (gitignored) and fill in.
NODE_ENV=development
PORT=3010

# Same DB the packages/db uses (non-superuser role so RLS applies).
DATABASE_URL="postgresql://pixsignpro:CHANGE_ME@localhost:5432/pixsignpro?schema=public"

# Web portal JWT (use long random strings in prod; rotate on suspicion).
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# Mobile app JWT — separate secrets from the web portal.
MOBILE_JWT_ACCESS_SECRET="change_me_mobile_access_secret"
MOBILE_ACCESS_TTL="15m"
# Refresh token lifetime in days (stored in DB; 30 is the default).
MOBILE_REFRESH_TTL_DAYS=30

# HMAC-SHA256 secret for signing short-lived media URLs served to the mobile app.
# Generate with: openssl rand -hex 32
MEDIA_SIGN_SECRET="change_me_media_sign_secret"

# Media storage root — outside any web root, owner-only perms.
STORAGE_DIR="/var/www/pixsignpro/storage"

# CORS allowlist (comma-separated). Empty = deny all cross-origin.
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Public base URL for building signed media URLs returned to the mobile app.
PUBLIC_BASE_URL="https://dev.pixsign.in"

# Firebase Cloud Messaging (push notifications). Absolute path to the Firebase
# service-account JSON (Firebase Console → Project Settings → Service Accounts →
# Generate new private key). Leave unset to disable push (send becomes a no-op).
FCM_SERVICE_ACCOUNT_PATH="/var/www/pixsignpro/secrets/fcm-service-account.json"
