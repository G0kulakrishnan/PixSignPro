{
  "name": "@pixsignpro/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "rls": "node ./scripts/apply-rls.mjs",
    "seed": "tsx src/seed.ts",
    "setup": "prisma migrate deploy && node ./scripts/apply-rls.mjs && tsx src/seed.ts",
    "studio": "prisma studio",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
