// PixSign Pro — Prisma schema
// Multitenancy: row-level `business_id` + Postgres RLS (see prisma/sql/rls.sql).
// All IDs are globally-unique UUIDs. `mobile_no` is globally unique across users.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessRole {
  business_admin
  media_admin
  staff
}

enum MediaType {
  image
  video
}

enum MediaEventType {
  download
  share
  view
}

enum SubscriptionStatus {
  active
  expired
  suspended
}

enum BillingPeriod {
  monthly
  quarterly
  yearly
}

/// Platform-level subscription plans (managed by super_admin). Not tenant-scoped.
model SubscriptionPlan {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  price         Decimal       @default(0) @db.Decimal(10, 2)
  currency      String        @default("INR")
  billingPeriod BillingPeriod @default(monthly) @map("billing_period")
  maxUsers      Int           @default(0) @map("max_users") // 0 = unlimited
  maxStorageMb  Int           @default(0) @map("max_storage_mb") // 0 = unlimited
  features      Json          @default("{}")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  businesses Business[]

  @@map("subscription_plans")
}

/// Tenant. One row per business. RLS: visible only when it is the current tenant.
model Business {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  agencyName         String?            @map("agency_name")
  city               String?
  logoUrl            String?            @map("logo_url")
  website            String?
  planId             String?            @map("plan_id") @db.Uuid
  subscriptionStatus SubscriptionStatus @default(active) @map("subscription_status")
  subscriptionStart  DateTime?          @map("subscription_start")
  subscriptionEnd    DateTime?          @map("subscription_end")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])
  users       User[]
  media       Media[]
  mediaEvents MediaEvent[]

  @@index([planId])
  @@map("businesses")
}

/// Portal users. `mobile_no` is GLOBALLY unique (login by mobile → derive business).
model User {
  id              String       @id @default(uuid()) @db.Uuid
  businessId      String       @map("business_id") @db.Uuid
  mobileNo        String       @unique @map("mobile_no")
  passwordHash    String       @map("password_hash")
  role            BusinessRole @default(staff)
  name            String
  profilePicUrl   String?      @map("profile_pic_url")
  companyLogoUrl  String?      @map("company_logo_url")
  agencyName      String?      @map("agency_name")
  city            String?
  youtube         String?
  website         String?
  instagram       String?
  optional1       String?
  optional2       String?
  lastAppOpenedAt DateTime?    @map("last_app_opened_at")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedMedia Media[]      @relation("UploadedBy")
  mediaEvents   MediaEvent[]

  @@index([businessId])
  @@map("users")
}

/// Platform operators. Not tenant-scoped; only reachable via the super_admin path.
model SuperAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  mobileNo     String   @unique @map("mobile_no")
  email        String?  @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

/// Uploaded image/video. Files live on disk; only metadata here.
model Media {
  id                 String    @id @default(uuid()) @db.Uuid
  businessId         String    @map("business_id") @db.Uuid
  type               MediaType
  title              String
  fileName           String    @map("file_name") // stored (UUID) filename on disk
  filePath           String    @map("file_path") // path within storage root
  fileSize           BigInt    @map("file_size") // bytes
  mimeType           String    @map("mime_type")
  uploadedById       String?   @map("uploaded_by") @db.Uuid
  scheduledPublishAt DateTime? @map("scheduled_publish_at")
  published          Boolean   @default(true)
  createdAt          DateTime  @default(now()) @map("created_at")

  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedBy User?        @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  events     MediaEvent[]

  @@index([businessId])
  @@index([businessId, type])
  @@index([businessId, published])
  @@index([scheduledPublishAt])
  @@map("media")
}

/// Analytics source: one row per tracked action (download / share / view / app-open).
model MediaEvent {
  id         String         @id @default(uuid()) @db.Uuid
  businessId String         @map("business_id") @db.Uuid
  mediaId    String?        @map("media_id") @db.Uuid
  userId     String?        @map("user_id") @db.Uuid
  eventType  MediaEventType @map("event_type")
  createdAt  DateTime       @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  media    Media?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, mediaId])
  @@index([businessId, userId])
  @@map("media_events")
}
